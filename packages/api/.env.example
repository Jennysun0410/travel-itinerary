# Database
DATABASE_URL=postgresql://user:password@localhost:5432/travel_itinerary

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth (Sign-In + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Microsoft / Outlook OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/auth/microsoft/callback

# Claude API (for email parsing)
ANTHROPIC_API_KEY=

# Gmail PubSub
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-push
GOOGLE_PUBSUB_SUBSCRIPTION=projects/YOUR_PROJECT/subscriptions/gmail-push-sub

# App
PORT=3001
NODE_ENV=development
ENCRYPTION_KEY=change-me-to-32-byte-hex-key
